generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Termin {
  id      String @id @default(cuid()) @db.VarChar(255)
  predmet String @db.VarChar(255)
  tip     String @db.VarChar(1)
  grupe   String @db.VarChar(50)
  od      String @db.VarChar(5)
  do      String @db.VarChar(5)
  sala    String @db.VarChar(50)
  dan     Int    @db.TinyInt()
  userId  String @db.VarChar(255)

  @@index([userId])
}

model Predmeti {
  id      String  @db.VarChar(255) @id @default(cuid())
  userId  String  @db.VarChar(255)
  godina  Int     @db.TinyInt()
  ime     String  @db.VarChar(255)  

  @@index([userId])
}